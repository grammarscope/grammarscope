<resources>

	<!-- T H E M E -->

	<!-- Action bar -->
	<style name="MyActionBarTheme" parent="ThemeOverlay.AppCompat.DayNight.ActionBar">
		<item name="android:background">?attr/colorPrimary</item> <!-- menu overflow, search view, title, subtitle backgrounds -->
		<item name="android:textColorPrimary">?attr/colorOnPrimary</item> <!-- search view foreground -->
		<item name="titleTextColor">?attr/colorOnPrimary</item> <!-- title foreground -->
		<item name="subtitleTextColor">?attr/colorHighlightOnPrimary</item> <!-- subtitle foreground -->
		<item name="colorControlNormal">?attr/colorOnPrimary</item> <!-- pictograms (menu overflow, search magnifying glass, navigation) -->
	</style>

	<!-- Action bar popup -->
	<style name="MyActionBarPopupTheme" parent="ThemeOverlay.AppCompat.DayNight">
		<item name="android:background">?attr/colorPrimary</item> <!-- submenu background -->
		<item name="android:textColorPrimary">?attr/colorOnPrimary</item> <!-- item foreground -->
		<item name="android:textColorSecondary">?attr/colorHighlightOnPrimary</item> <!-- submenu item foreground -->
	</style>


	<!-- S T Y L E S -->

	<!-- Action bar -->
	<style name="MyActionBarStyle" parent="Widget.AppCompat.ActionBar">
		<item name="android:background">?attr/colorPrimary</item> <!-- whole actionbar background -->
	</style>

	<!-- Toolbar -->
	<style name="MyToolbarStyle" parent="Widget.AppCompat.Toolbar">
		<item name="android:background">?attr/colorPrimary</item>
	</style>

	<!-- Dropdown list -->
	<!--	<style name="MyDropDownListViewStyle" parent="Widget.AppCompat.ListView.DropDown">-->
	<!--		<item name="android:background">?attr/colorPrimary</item>-->
	<!--	</style>-->

	<!-- Dropdown item -->
	<!--	<style name="MyDropDownItemStyle" parent="Widget.AppCompat.DropDownItem.Spinner">-->
	<!--		<item name="android:textColor">?attr/colorOnPrimary</item>-->
	<!--		<item name="android:textSize">14sp</item>-->
	<!--	</style>-->

	<!-- Custom surface overlay -->
	<style name="MySurfaceOverlay" parent="ThemeOverlay.Material3">
		<item name="android:background">?attr/colorCustom</item>
		<item name="android:textColor">?attr/colorOnCustom</item>
	</style>

	<!-- S T Y L E S -->

	<!-- App bar -->
	<style name="MyAppBarLayout" parent="Widget.Material3.AppBarLayout">
		<item name="android:background">?attr/colorCustom</item>
		<item name="android:textColor">?attr/colorOnCustom</item>
		<!-- This prevents the AppBarLayout from applying an elevation overlay that would cover the statusBarColor -->
		<item name="liftOnScroll">false</item>
	</style>

	<!-- Search view -->
	<style name="MySearchViewStyle" parent="Widget.Material3.SearchView">
		<item name="backgroundTint">?attr/colorCustom</item>
	</style>

	<!-- Dropdown list -->
	<style name="MyDropDownListViewStyle" parent="Widget.AppCompat.ListView.DropDown">
		<item name="android:background">?attr/colorCustom</item>
		<item name="android:textColor">?attr/colorOnCustom</item>
	</style>

	<!-- Dropdown item -->
	<style name="MyDropDownItemStyle" parent="Widget.AppCompat.DropDownItem.Spinner">
		<item name="android:background">?attr/colorCustom</item>
		<item name="android:textColor">?attr/colorOnCustom</item>
		<item name="android:textSize">14sp</item>
	</style>

	<!-- Autocomplete -->
	<style name="MyAutoCompleteTextViewStyle" parent="Widget.AppCompat.Light.AutoCompleteTextView">
		<item name="android:popupBackground">?attr/colorCustom</item>
	</style>
</resources>